# OpenAI API key for the Analytics Assistant chat (LLM)
# Get your key at https://platform.openai.com/api-keys

# Server-side key (recommended for local dev)
OPENAI_API_KEY=sk-your-key-here

# Public/demo key - baked into frontend, works without server env.
# Use for demos; prefer OPENAI_API_KEY for production.
# VITE_OPENAI_API_KEY=sk-your-public-key
