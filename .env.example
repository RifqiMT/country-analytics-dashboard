PORT=4000
# Frontend API base URL. Leave empty when frontend and API are served from the same Vercel project.
# VITE_API_BASE_URL=
# Optional — enables narrative PESTEL, Porter, and Assistant replies
GROQ_API_KEY=
#
# Groq models are routed per feature (see backend/src/llm.ts — GroqUseCase).
# Optional legacy: applies as primary for any use case that does not set its own GROQ_MODEL_* below.
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Per-feature primary (overrides GROQ_MODEL for that surface only when set):
# GROQ_MODEL_PESTEL=llama-3.3-70b-versatile
# GROQ_MODEL_PORTER=openai/gpt-oss-120b
# GROQ_MODEL_ASSISTANT=llama-3.1-8b-instant
#
# Per-feature fallback chains (comma-separated), then global GROQ_FALLBACK_MODELS, then built-ins:
# GROQ_FALLBACK_MODELS_PESTEL=llama-3.1-8b-instant,openai/gpt-oss-120b
# GROQ_FALLBACK_MODELS_PORTER=llama-3.3-70b-versatile,llama-3.1-8b-instant
# GROQ_FALLBACK_MODELS_ASSISTANT=llama-3.3-70b-versatile,openai/gpt-oss-120b
# Optional global fallbacks after the per-use-case list:
# GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,qwen/qwen3-32b

# Optional — web retrieval layer before Groq; also used as Assistant fallback when all Groq models fail
TAVILY_API_KEY=

# Set to 1 to skip background prefetch of all country metric bundles on first UI load
# DISABLE_BOOTSTRAP_WARMUP=1
