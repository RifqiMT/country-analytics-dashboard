# Analytics Assistant – API keys for LLM and web search providers
# Server-side keys: used when no user key; enables all users without sign-up
# Client-side keys (VITE_*): baked into frontend for public/demo use
# Obtain keys from each provider's developer console – never commit real keys

# ─── Free-tier LLM (general-knowledge questions) ───
# When set, used for requests when no user API key is provided
GROQ_API_KEY=your-key-here
# VITE_GROQ_API_KEY=your-key-here

# ─── Web search – real-time answers (leaders, current events) ───
# Used when LLM fails or for latest data; one of the two below
TAVILY_API_KEY=your-key-here
# SERPER_API_KEY=your-key-here

# ─── Premium LLM providers ───
OPENAI_API_KEY=your-key-here
# VITE_OPENAI_API_KEY=your-key-here

ANTHROPIC_API_KEY=your-key-here
# VITE_ANTHROPIC_API_KEY=your-key-here

GOOGLE_AI_API_KEY=your-key-here
# VITE_GOOGLE_AI_API_KEY=your-key-here

OPENROUTER_API_KEY=your-key-here
# VITE_OPENROUTER_API_KEY=your-key-here
